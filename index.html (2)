    movies: [
      { title: "CODA", year: 2021, link: "https://example.com/embed/coda" },
      { title: "Killers of the Flower Moon", year: 2023, link: "https://example.com/embed/killers" },
      { title: "Napoleon", year: 2023, link: "https://example.com/embed/napoleon" }
    ],
    series: [
      { title: "Foundation", year: 2021, seasons: 2, link: "https://example.com/embed/foundation" },
      { title: "The Morning Show", year: 2019, seasons: 4, link: "https://example.com/embed/morning-show" },
      { title: "Severance", year: 2022, seasons: 2, link: "https://example.com/embed/severance" },
      { title: "Slow Horses", year: 2022, seasons: 4, link: "https://example.com/embed/slow-horses" },
      { title: "Ted Lasso", year: 2020, seasons: 3, link: "https://example.com/embed/ted-lasso" }
    ]
  }
};

/* =========================================================
   STATE
   ========================================================= */
const state = {
  view: "platforms",   // platforms | types | titles
  platform: null,      // key in DATA
  type: null,          // 'movies' | 'series'
  search: ""
};

const app = document.getElementById("app");
const breadcrumb = document.getElementById("breadcrumb");
const searchWrap = document.getElementById("searchWrap");
const searchInput = document.getElementById("search");
const modal = document.getElementById("modal");
const player = document.getElementById("player");
const modalTitle = document.getElementById("modalTitle");
const closeBtn = document.getElementById("closeBtn");
const copyBtn = document.getElementById("copyBtn");
const logo = document.getElementById("logo");
const toast = document.getElementById("toast");

let currentLink = "";

/* =========================================================
   RENDERING
   ========================================================= */
function render() {
  app.innerHTML = "";
  renderBreadcrumb();
  toggleSearch();

  if (state.view === "platforms") return renderPlatforms();
  if (state.view === "types") return renderTypes();
  if (state.view === "titles") return renderTitles();
}

function renderBreadcrumb() {
  const parts = [];
  parts.push(`<span class="crumb" data-nav="platforms">Home</span>`);
  if (state.platform) {
    parts.push(`<span class="sep">/</span>`);
    const isLeaf = state.view === "types";
    parts.push(isLeaf
      ? `<span class="current">${DATA[state.platform].name}</span>`
      : `<span class="crumb" data-nav="types">${DATA[state.platform].name}</span>`);
  }
  if (state.type) {
    parts.push(`<span class="sep">/</span>`);
    parts.push(`<span class="current">${state.type === "movies" ? "Movies" : "Series"}</span>`);
  }
  breadcrumb.innerHTML = parts.join("");
  breadcrumb.querySelectorAll(".crumb").forEach(el => {
    el.addEventListener("click", () => {
      const nav = el.dataset.nav;
      if (nav === "platforms") goHome();
      else if (nav === "types") goTypes(state.platform);
    });
  });
}

function toggleSearch() {
  if (state.view === "titles") {
    searchWrap.classList.remove("hidden");
  } else {
    searchWrap.classList.add("hidden");
    searchInput.value = "";
    state.search = "";
  }
}

function renderPlatforms() {
  const view = document.createElement("div");
  view.className = "view";
  view.innerHTML = `
    <h1 class="page-title">Choose a platform</h1>
    <p class="page-subtitle">Browse the archive by streaming service.</p>
    <div class="platform-list" id="platformList"></div>
  `;
  app.appendChild(view);

  const list = view.querySelector("#platformList");
  Object.entries(DATA).forEach(([key, plat]) => {
    const total = plat.movies.length + plat.series.length;
    const btn = document.createElement("button");
    btn.className = "platform-card";
    btn.innerHTML = `
      <div>
        <div class="name">${plat.name}</div>
        <div class="meta">${plat.movies.length} movies · ${plat.series.length} series</div>
      </div>
      <span class="arrow" aria-hidden="true">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
      </span>
    `;
    btn.addEventListener("click", () => goTypes(key));
    list.appendChild(btn);
  });
}

function renderTypes() {
  const plat = DATA[state.platform];
  const view = document.createElement("div");
  view.className = "view";
  view.innerHTML = `
    <button class="back-btn" id="backBtn">← Back</button>
    <h1 class="page-title">${plat.name}</h1>
    <p class="page-subtitle">What would you like to watch?</p>
    <div class="type-list">
      <button class="type-card" data-type="movies">
        <div class="label">Movies</div>
        <div class="count">${plat.movies.length} titles</div>
      </button>
      <button class="type-card" data-type="series">
        <div class="label">Series</div>
        <div class="count">${plat.series.length} titles</div>
      </button>
    </div>
  `;
  app.appendChild(view);

  view.querySelector("#backBtn").addEventListener("click", goHome);
  view.querySelectorAll(".type-card").forEach(card => {
    card.addEventListener("click", () => goTitles(state.platform, card.dataset.type));
  });
}

function renderTitles() {
  const plat = DATA[state.platform];
  const items = plat[state.type] || [];
  const view = document.createElement("div");
  view.className = "view";
  view.innerHTML = `
    <button class="back-btn" id="backBtn">← Back</button>
    <h1 class="page-title">${plat.name} — ${state.type === "movies" ? "Movies" : "Series"}</h1>
    <p class="page-subtitle">${items.length} title${items.length === 1 ? "" : "s"} available.</p>
    <div id="titleArea"></div>
  `;
  app.appendChild(view);

  view.querySelector("#backBtn").addEventListener("click", () => goTypes(state.platform));
  renderTitleList(items);
}

function renderTitleList(items) {
  const area = document.getElementById("titleArea");
  if (!area) return;
  const query = state.search.trim().toLowerCase();
  const filtered = query
    ? items.filter(i => i.title.toLowerCase().includes(query))
    : items.slice();

  filtered.sort((a, b) => a.title.localeCompare(b.title));

  if (filtered.length === 0) {
    area.innerHTML = `
      <div class="empty-state">
        <div class="icon">∅</div>
        <p>No titles match "<strong>${escapeHtml(state.search)}</strong>".</p>
      </div>
    `;
    return;
  }

  // Group by first letter
  const groups = {};
  filtered.forEach(item => {
    const ch = item.title.charAt(0).toUpperCase();
    const letter = /[A-Z]/.test(ch) ? ch : "#";
    if (!groups[letter]) groups[letter] = [];
    groups[letter].push(item);
  });

  const letters = Object.keys(groups).sort();
  area.innerHTML = letters.map(letter => `
    <section class="letter-group">
      <h2 class="letter-heading">
        <span>${letter}</span>
        <span class="count-badge">${groups[letter].length}</span>
      </h2>
      <div class="titles">
        ${groups[letter].map(item => {
          const idx = filtered.indexOf(item);
          const metaParts = [];
          if (item.year) metaParts.push(`<span>${item.year}</span>`);
          if (typeof item.seasons === "number") {
            metaParts.push(`<span class="dot"></span>`);
            metaParts.push(`<span>${item.seasons} season${item.seasons === 1 ? "" : "s"}</span>`);
          }
          const metaHtml = metaParts.length
            ? `<span class="t-meta">${metaParts.join("")}</span>`
            : "";
          return `
          <button class="title-item" data-idx="${idx}" data-title="${escapeAttr(item.title)}">
            <span class="t-name">${escapeHtml(item.title)}</span>
            ${metaHtml}
          </button>
        `;
        }).join("")}
      </div>
    </section>
  `).join("");

  area.querySelectorAll(".title-item").forEach(btn => {
    btn.addEventListener("click", () => {
      const item = filtered[parseInt(btn.dataset.idx, 10)];
      if (item) handleTitleClick(item);
    });
  });
}

/* =========================================================
   SOURCE RESOLUTION
   ========================================================= */
function getSources(item) {
  const out = [];
  if (item && item.links) {
    if (item.links.drive) out.push({ kind: "drive", url: item.links.drive });
    if (item.links.telegram) out.push({ kind: "telegram", url: item.links.telegram });
  }
  if (item && item.link && out.length === 0) {
    out.push({ kind: "drive", url: item.link });
  }
  return out;
}

function handleTitleClick(item) {
  const sources = getSources(item);
  if (sources.length === 0) return;
  if (sources.length === 1) {
    window.open(sources[0].url, "_blank", "noopener,noreferrer");
    return;
  }
  openSourceModal(item, sources);
}

/* =========================================================
   NAVIGATION
   ========================================================= */
function goHome() {
  state.view = "platforms";
  state.platform = null;
  state.type = null;
  state.search = "";
  render();
}
function goTypes(platformKey) {
  state.view = "types";
  state.platform = platformKey;
  state.type = null;
  render();
}
function goTitles(platformKey, type) {
  state.view = "titles";
  state.platform = platformKey;
  state.type = type;
  render();
}

/* =========================================================
   MODAL
   ========================================================= */
function openModal(title, link) {
  currentLink = link;
  modalTitle.textContent = title;
  player.src = link;
  modal.classList.add("open");
  document.body.classList.add("modal-open");
}
function closeModal() {
  modal.classList.remove("open");
  player.src = "";          // stops video
  document.body.classList.remove("modal-open");
  currentLink = "";
  copyBtn.classList.remove("copied");
}

closeBtn.addEventListener("click", closeModal);
modal.addEventListener("click", (e) => {
  if (e.target === modal) closeModal();
});
document.addEventListener("keydown", (e) => {
  if (e.key !== "Escape") return;
  if (sourceModal.classList.contains("open")) closeSourceModal();
  else if (modal.classList.contains("open")) closeModal();
});

/* =========================================================
   SOURCE SELECTION MODAL
   ========================================================= */
const sourceModal = document.getElementById("sourceModal");
const sourceTitleEl = document.getElementById("sourceTitle");
const sourceDriveBtn = document.getElementById("sourceDrive");
const sourceTelegramBtn = document.getElementById("sourceTelegram");
const sourceCancelBtn = document.getElementById("sourceCancel");

let activeSources = { drive: null, telegram: null };

function openSourceModal(item, sources) {
  activeSources = { drive: null, telegram: null };
  sources.forEach(s => { activeSources[s.kind] = s.url; });
  sourceTitleEl.textContent = item.title;
  sourceDriveBtn.style.display = activeSources.drive ? "" : "none";
  sourceTelegramBtn.style.display = activeSources.telegram ? "" : "none";
  sourceModal.classList.add("open");
  document.body.classList.add("modal-open");
}
function closeSourceModal() {
  sourceModal.classList.remove("open");
  document.body.classList.remove("modal-open");
  activeSources = { drive: null, telegram: null };
}
sourceDriveBtn.addEventListener("click", () => {
  if (activeSources.drive) window.open(activeSources.drive, "_blank", "noopener,noreferrer");
  closeSourceModal();
});
sourceTelegramBtn.addEventListener("click", () => {
  if (activeSources.telegram) window.open(activeSources.telegram, "_blank", "noopener,noreferrer");
  closeSourceModal();
});
sourceCancelBtn.addEventListener("click", closeSourceModal);
sourceModal.addEventListener("click", (e) => {
  if (e.target === sourceModal) closeSourceModal();
});

copyBtn.addEventListener("click", async () => {
  if (!currentLink) return;
  try {
    await navigator.clipboard.writeText(currentLink);
  } catch {
    const ta = document.createElement("textarea");
    ta.value = currentLink;
    document.body.appendChild(ta);
    ta.select();
    try { document.execCommand("copy"); } catch {}
    document.body.removeChild(ta);
  }
  copyBtn.classList.add("copied");
  showToast("Link copied to clipboard");
  setTimeout(() => copyBtn.classList.remove("copied"), 1500);
});

/* =========================================================
   SEARCH
   ========================================================= */
searchInput.addEventListener("input", (e) => {
  state.search = e.target.value;
  if (state.view === "titles") {
    const items = DATA[state.platform][state.type] || [];
    renderTitleList(items);
  }
});

logo.addEventListener("click", goHome);

/* =========================================================
   UTILITIES
   ========================================================= */
function escapeHtml(s) {
  return String(s).replace(/[&<>"']/g, m => ({
    "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;", "'": "&#39;"
  }[m]));
}
function escapeAttr(s) { return escapeHtml(s); }

let toastTimer;
function showToast(msg) {
  toast.textContent = msg;
  toast.classList.add("show");
  clearTimeout(toastTimer);
  toastTimer = setTimeout(() => toast.classList.remove("show"), 1800);
}

/* =========================================================
   INIT
   ========================================================= */
render();
</script>
