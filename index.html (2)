<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>Streamverse — Archive</title>
<meta name="description" content="A lightweight, text-only streaming archive. Browse platforms, movies, and series." />
<style>
  :root {
    --bg: #0b0b0b;
    --bg-elev: #141414;
    --bg-elev-2: #1f1f1f;
    --border: #2a2a2a;
    --text: #f5f5f5;
    --text-dim: #a3a3a3;
    --text-mute: #6b6b6b;
    --accent: #e50914;
    --accent-hover: #f6121d;
    --radius: 10px;
    --shadow: 0 10px 30px rgba(0,0,0,.5);
    --transition: 200ms cubic-bezier(.2,.7,.2,1);
  }

  * { box-sizing: border-box; }
  html { scroll-behavior: smooth; }
  body {
    margin: 0;
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
    background: var(--bg);
    color: var(--text);
    -webkit-font-smoothing: antialiased;
    min-height: 100vh;
    overflow-x: hidden;
  }
  body.modal-open { overflow: hidden; }

  /* Header */
  header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: rgba(11,11,11,.85);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border);
  }
  .header-inner {
    max-width: 1100px;
    margin: 0 auto;
    padding: 18px 24px;
    display: flex;
    align-items: center;
    gap: 20px;
    flex-wrap: wrap;
  }
  .logo {
    font-weight: 800;
    font-size: 22px;
    letter-spacing: .5px;
    color: var(--accent);
    text-transform: uppercase;
    cursor: pointer;
    user-select: none;
  }
  .logo span { color: var(--text); }

  .breadcrumb {
    flex: 1;
    color: var(--text-dim);
    font-size: 14px;
    min-width: 120px;
  }
  .breadcrumb .crumb {
    cursor: pointer;
    transition: color var(--transition);
  }
  .breadcrumb .crumb:hover { color: var(--text); }
  .breadcrumb .sep { margin: 0 8px; color: var(--text-mute); }
  .breadcrumb .current { color: var(--text); font-weight: 600; }

  .search-wrap {
    position: relative;
    flex: 0 1 280px;
  }
  .search-wrap.hidden { display: none; }
  .search-input {
    width: 100%;
    background: var(--bg-elev);
    border: 1px solid var(--border);
    color: var(--text);
    padding: 10px 14px 10px 38px;
    border-radius: var(--radius);
    font-size: 14px;
    outline: none;
    transition: border-color var(--transition), background var(--transition);
  }
  .search-input::placeholder { color: var(--text-mute); }
  .search-input:focus {
    border-color: var(--accent);
    background: var(--bg-elev-2);
  }
  .search-icon {
    position: absolute;
    left: 12px;
    top: 50%;
    transform: translateY(-50%);
    color: var(--text-mute);
    pointer-events: none;
  }

  main {
    max-width: 1100px;
    margin: 0 auto;
    padding: 40px 24px 80px;
  }

  .page-title {
    font-size: clamp(28px, 4vw, 40px);
    margin: 0 0 8px;
    font-weight: 800;
    letter-spacing: -.5px;
  }
  .page-subtitle {
    color: var(--text-dim);
    margin: 0 0 32px;
    font-size: 15px;
  }

  /* Platform list */
  .platform-list {
    display: flex;
    flex-direction: column;
    gap: 14px;
    max-width: 560px;
    margin: 0 auto;
  }
  .platform-card {
    background: var(--bg-elev);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 22px 26px;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: space-between;
    transition: all var(--transition);
    text-align: left;
    width: 100%;
    color: var(--text);
    font-family: inherit;
  }
  .platform-card:hover {
    background: var(--bg-elev-2);
    border-color: var(--accent);
    transform: translateY(-2px);
    box-shadow: var(--shadow);
  }
  .platform-card .name {
    font-size: 18px;
    font-weight: 700;
    letter-spacing: .3px;
  }
  .platform-card .meta {
    color: var(--text-mute);
    font-size: 13px;
  }
  .platform-card .arrow {
    color: var(--text-mute);
    transition: transform var(--transition), color var(--transition);
  }
  .platform-card:hover .arrow {
    color: var(--accent);
    transform: translateX(4px);
  }

  /* Type selector */
  .type-list {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
    max-width: 560px;
    margin: 0 auto;
  }
  .type-card {
    background: var(--bg-elev);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 36px 24px;
    cursor: pointer;
    text-align: center;
    transition: all var(--transition);
    color: var(--text);
    font-family: inherit;
  }
  .type-card:hover {
    background: var(--bg-elev-2);
    border-color: var(--accent);
    transform: translateY(-3px);
    box-shadow: var(--shadow);
  }
  .type-card .label {
    font-size: 20px;
    font-weight: 700;
    margin-bottom: 6px;
  }
  .type-card .count {
    color: var(--text-mute);
    font-size: 13px;
  }

  /* Title list */
  .letter-group { margin-bottom: 36px; }
  .letter-heading {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    font-size: 22px;
    font-weight: 800;
    color: var(--text);
    margin: 0 0 16px;
    padding: 8px 16px 8px 14px;
    background: linear-gradient(90deg, rgba(229,9,20,.18), rgba(229,9,20,0));
    border-left: 4px solid var(--accent);
    border-radius: 4px;
    letter-spacing: 1px;
    text-transform: uppercase;
  }
  .letter-heading .count-badge {
    font-size: 11px;
    font-weight: 600;
    color: var(--text-mute);
    background: var(--bg-elev-2);
    padding: 2px 8px;
    border-radius: 10px;
    letter-spacing: .5px;
  }
  .titles {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 10px;
    align-items: stretch;
  }
  .title-item {
    background: var(--bg-elev);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 12px 16px;
    cursor: pointer;
    color: var(--text);
    text-align: left;
    transition: transform 220ms cubic-bezier(.2,.7,.2,1),
                background 220ms ease,
                border-color 220ms ease,
                box-shadow 220ms ease;
    font-family: inherit;
    display: flex;
    flex-direction: column;
    gap: 4px;
    min-height: 64px;
  }
  .title-item .t-name {
    font-size: 15px;
    font-weight: 600;
    line-height: 1.3;
    color: var(--text);
  }
  .title-item .t-meta {
    font-size: 12px;
    color: var(--text-mute);
    font-weight: 500;
    letter-spacing: .3px;
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .title-item .t-meta .dot {
    width: 3px;
    height: 3px;
    border-radius: 50%;
    background: var(--text-mute);
    display: inline-block;
  }
  .title-item:hover {
    background: var(--bg-elev-2);
    border-color: var(--accent);
    transform: translateY(-2px) scale(1.015);
    box-shadow: 0 8px 24px rgba(229,9,20,.15);
  }
  .title-item:hover .t-name { color: var(--accent); }
  .title-item:hover .t-meta { color: var(--text-dim); }

  .empty-state {
    text-align: center;
    padding: 60px 20px;
    color: var(--text-mute);
  }
  .empty-state .icon { font-size: 40px; margin-bottom: 12px; }

  /* Back button */
  .back-btn {
    background: transparent;
    border: 1px solid var(--border);
    color: var(--text-dim);
    padding: 8px 16px;
    border-radius: var(--radius);
    cursor: pointer;
    font-size: 13px;
    margin-bottom: 24px;
    transition: all var(--transition);
    font-family: inherit;
  }
  .back-btn:hover {
    border-color: var(--accent);
    color: var(--text);
  }

  /* Modal */
  .modal {
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,.92);
    z-index: 100;
    display: none;
    align-items: center;
    justify-content: center;
    padding: 20px;
    animation: fadeIn 200ms ease;
  }
  .modal.open { display: flex; }
  @keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }

  .modal-content {
    width: 100%;
    max-width: 1100px;
    background: var(--bg-elev);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    overflow: hidden;
    box-shadow: var(--shadow);
    animation: slideUp 250ms cubic-bezier(.2,.7,.2,1);
  }
  @keyframes slideUp {
    from { transform: translateY(20px); opacity: 0; }
    to { transform: translateY(0); opacity: 1; }
  }

  .modal-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 14px 18px;
    border-bottom: 1px solid var(--border);
    gap: 12px;
  }
  .modal-title {
    font-size: 16px;
    font-weight: 700;
    margin: 0;
    flex: 1;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .modal-actions { display: flex; gap: 8px; }
  .icon-btn {
    background: var(--bg-elev-2);
    border: 1px solid var(--border);
    color: var(--text-dim);
    width: 36px;
    height: 36px;
    border-radius: 8px;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    transition: all var(--transition);
    font-family: inherit;
  }
  .icon-btn:hover {
    background: var(--accent);
    color: white;
    border-color: var(--accent);
  }
  .icon-btn.copied {
    background: #16a34a;
    border-color: #16a34a;
    color: white;
  }

  .video-wrap {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 9;
    background: #000;
  }
  .video-wrap iframe {
    width: 100%;
    height: 100%;
    border: 0;
  }

  /* Animations */
  .view {
    animation: viewIn 250ms ease;
  }
  @keyframes viewIn {
    from { opacity: 0; transform: translateY(8px); }
    to { opacity: 1; transform: translateY(0); }
  }

  /* Responsive */
  @media (max-width: 640px) {
    .header-inner { padding: 14px 16px; gap: 12px; }
    .breadcrumb { order: 3; flex-basis: 100%; }
    .search-wrap { flex: 1; }
    main { padding: 24px 16px 60px; }
    .type-list { grid-template-columns: 1fr; }
    .platform-card { padding: 18px 20px; }
    .titles { grid-template-columns: 1fr; }
    .modal { padding: 0; }
    .modal-content { border-radius: 0; height: 100%; display: flex; flex-direction: column; }
    .video-wrap { flex: 1; aspect-ratio: auto; }
  }

  /* Scrollbar */
  ::-webkit-scrollbar { width: 10px; }
  ::-webkit-scrollbar-track { background: var(--bg); }
  ::-webkit-scrollbar-thumb { background: var(--bg-elev-2); border-radius: 10px; }
  ::-webkit-scrollbar-thumb:hover { background: var(--accent); }

  /* Source selection modal */
  .source-modal {
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,.85);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    z-index: 150;
    display: none;
    align-items: center;
    justify-content: center;
    padding: 20px;
    animation: fadeIn 180ms ease;
  }
  .source-modal.open { display: flex; }
  .source-card {
    width: 100%;
    max-width: 380px;
    background: var(--bg-elev);
    border: 1px solid var(--border);
    border-radius: 14px;
    padding: 26px 24px 22px;
    box-shadow: var(--shadow);
    animation: sourcePop 220ms cubic-bezier(.2,.7,.2,1);
    text-align: center;
  }
  @keyframes sourcePop {
    from { transform: translateY(12px) scale(.96); opacity: 0; }
    to { transform: translateY(0) scale(1); opacity: 1; }
  }
  .source-eyebrow {
    color: var(--text-mute);
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    margin: 0 0 6px;
  }
  .source-title {
    font-size: 18px;
    font-weight: 700;
    margin: 0 0 18px;
    color: var(--text);
    word-break: break-word;
  }
  .source-buttons {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .source-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    width: 100%;
    padding: 14px 18px;
    border-radius: 10px;
    border: 1px solid var(--border);
    background: var(--bg-elev-2);
    color: var(--text);
    font-family: inherit;
    font-size: 15px;
    font-weight: 600;
    cursor: pointer;
    transition: all var(--transition);
  }
  .source-btn:hover {
    border-color: var(--accent);
    background: #262626;
    transform: translateY(-1px);
  }
  .source-btn svg { flex-shrink: 0; }
  .source-btn.drive:hover { color: #4285f4; }
  .source-btn.telegram:hover { color: #29b6f6; }
  .source-cancel {
    margin-top: 14px;
    background: transparent;
    border: none;
    color: var(--text-mute);
    font-size: 13px;
    cursor: pointer;
    font-family: inherit;
    transition: color var(--transition);
  }
  .source-cancel:hover { color: var(--text); }

  /* Toast */
  .toast {
    position: fixed;
    bottom: 24px;
    left: 50%;
    transform: translateX(-50%) translateY(100px);
    background: var(--bg-elev-2);
    border: 1px solid var(--border);
    color: var(--text);
    padding: 12px 20px;
    border-radius: var(--radius);
    font-size: 14px;
    z-index: 200;
    transition: transform 250ms cubic-bezier(.2,.7,.2,1);
    box-shadow: var(--shadow);
  }
  .toast.show { transform: translateX(-50%) translateY(0); }
</style>
</head>
